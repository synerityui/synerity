{
  "name": "@synerity/memory-graph",
  "version": "0.1.0",
  "description": "Zero-dependency in-memory knowledge graph for LLM context management",
  "keywords": [
    "llm",
    "memory",
    "knowledge-graph",
    "context",
    "ai"
  ],
  "license": "MIT",
  "homepage": "https://synerity.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/synerityui/synerity.git",
    "directory": "packages/memory-graph"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@synerity/eslint-config": "workspace:*",
    "@synerity/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
