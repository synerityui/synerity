{
  "name": "@synerity/tokens",
  "version": "0.1.0",
  "description": "Synerity Tokens — design tokens and CSS custom properties",
  "keywords": [
    "design-tokens",
    "css-variables",
    "theming",
    "design-system"
  ],
  "license": "MIT",
  "homepage": "https://synerity.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/synerityui/synerity.git",
    "directory": "packages/tokens"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./css": "./dist/tokens.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/tokens.ts --format cjs --outDir dist --no-dts && node scripts/build.js",
    "dev": "tsup src/tokens.ts --format cjs --outDir dist --no-dts --watch",
    "lint": "eslint scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@synerity/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^1.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
